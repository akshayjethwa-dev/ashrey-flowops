rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives & Auth ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to fetch user profiles
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserTenantId() {
      return getUser().tenantId;
    }

    function getUserRole() {
      return getUser().role;
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && getUserTenantId() == tenantId;
    }

    // --- Entity Specific Validation Helpers ---
    function isValidTenant(data) {
      return data.keys().hasAll(['id', 'companyName']) 
        && data.keys().size() >= 2 
        && data.companyName is string 
        && data.companyName.size() <= 150;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'tenantId', 'role'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.name is string
        && data.name.size() <= 150
        && data.tenantId is string
        && data.role in ['admin', 'sales', 'production', 'dispatch', 'management'];
    }

    function isValidRFQ(data) {
      return data.keys().hasAll(['id', 'tenantId', 'customerName', 'status', 'createdAt', 'createdBy'])
        && data.id is string
        && data.tenantId is string
        && data.customerName is string
        && data.customerName.size() <= 200
        && data.status in ['pending', 'quoted', 'declined']
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['id', 'tenantId', 'rfqId', 'quoteNumber', 'customerName', 'status', 'total', 'createdAt', 'createdBy'])
        && data.id is string
        && data.tenantId is string
        && data.rfqId is string
        && data.quoteNumber is string
        && data.customerName is string
        && data.customerName.size() <= 200
        && data.status in ['draft', 'sent', 'approved', 'rejected']
        && data.total is number
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'tenantId', 'orderNumber', 'customerName', 'status', 'totalAmount', 'createdAt', 'createdBy'])
        && data.id is string
        && data.tenantId is string
        && data.orderNumber is string
        && data.customerName is string
        && data.customerName.size() <= 200
        && data.status in ['pending', 'in-production', 'produced', 'dispatched', 'completed', 'cancelled']
        && data.totalAmount is number
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidProductionJob(data) {
      return data.keys().hasAll(['id', 'tenantId', 'orderId', 'itemName', 'quantity', 'currentStage', 'updatedAt', 'updatedBy'])
        && data.id is string
        && data.tenantId is string
        && data.orderId is string
        && data.itemName is string
        && data.itemName.size() <= 200
        && data.quantity is number
        && data.currentStage in ['cutting', 'welding', 'machining', 'assembly', 'quality_check', 'ready']
        && data.updatedBy == request.auth.uid
        && data.updatedAt == request.time;
    }

    function isValidDispatch(data) {
      return data.keys().hasAll(['id', 'tenantId', 'orderId', 'invoiceNumber', 'status', 'dispatchedAt'])
        && data.id is string
        && data.tenantId is string
        && data.orderId is string
        && data.invoiceNumber is string
        && data.status in ['shipped', 'delivered']
        && data.dispatchedAt == request.time;
    }

    function isValidWhatsAppLog(data) {
      return data.keys().hasAll(['id', 'tenantId', 'recipientPhone', 'message', 'status', 'sentAt'])
        && data.id is string
        && data.tenantId is string
        && data.recipientPhone is string
        && data.recipientPhone.size() <= 20
        && data.message is string
        && data.status in ['sent', 'failed', 'pending']
        && data.sentAt == request.time;
    }

    // --- Match Rules for Collections ---

    // 1. Tenants Collection
    match /tenants/{tenantId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidId(tenantId) && isValidTenant(incoming());
      allow update: if isSignedIn() && isValidId(tenantId) && isTenantMember(tenantId) && getUserRole() == 'admin' && isValidTenant(incoming());
      allow delete: if false;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      // Allow a user to create their own first profile registration
      allow create: if request.auth != null && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (
        // Allow updating own name/phone (blocking self-elevating role changes)
        (request.auth.uid == userId && incoming().tenantId == existing().tenantId && incoming().role == existing().role && isValidUser(incoming())) ||
        // Allow Admins to update user fields
        (getUserTenantId() == existing().tenantId && getUserRole() == 'admin' && incoming().tenantId == existing().tenantId && isValidUser(incoming()))
      );
      allow delete: if false;
    }

    // 3. RFQs Collection
    match /rfqs/{rfqId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(rfqId) && isTenantMember(incoming().tenantId) && getUserRole() in ['admin', 'sales', 'management'] && isValidRFQ(incoming());
      allow update: if isSignedIn() && isValidId(rfqId) && isTenantMember(existing().tenantId) && getUserRole() in ['admin', 'sales', 'management'] && isValidRFQ(incoming()) 
        && incoming().tenantId == existing().tenantId && incoming().rfqId == existing().rfqId;
      allow delete: if false;
    }

    // 4. Quotes Collection
    match /quotes/{quoteId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(quoteId) && isTenantMember(incoming().tenantId) && getUserRole() in ['admin', 'sales', 'management'] 
        && exists(/databases/$(database)/documents/rfqs/$(incoming().rfqId)) && isValidQuote(incoming());
      allow update: if isSignedIn() && isValidId(quoteId) && isTenantMember(existing().tenantId) && getUserRole() in ['admin', 'sales', 'management'] 
        && isValidQuote(incoming()) && incoming().tenantId == existing().tenantId && incoming().rfqId == existing().rfqId;
      allow delete: if false;
    }

    // 5. Orders Collection
    match /orders/{orderId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(orderId) && isTenantMember(incoming().tenantId) && getUserRole() in ['admin', 'sales', 'management'] 
        && exists(/databases/$(database)/documents/quotes/$(incoming().quoteId)) && isValidOrder(incoming());
      allow update: if isSignedIn() && isValidId(orderId) && isTenantMember(existing().tenantId) 
        && (getUserRole() in ['admin', 'sales', 'management'] || (getUserRole() == 'production' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])))
        && isValidOrder(incoming()) && incoming().tenantId == existing().tenantId && incoming().quoteId == existing().quoteId;
      allow delete: if false;
    }

    // 6. ProductionJobs Collection
    match /productionJobs/{jobId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(jobId) && isTenantMember(incoming().tenantId) && getUserRole() in ['admin', 'sales', 'production', 'management'] 
        && exists(/databases/$(database)/documents/orders/$(incoming().orderId)) && isValidProductionJob(incoming());
      allow update: if isSignedIn() && isValidId(jobId) && isTenantMember(existing().tenantId) && getUserRole() in ['admin', 'production', 'management'] 
        && isValidProductionJob(incoming()) && incoming().tenantId == existing().tenantId && incoming().orderId == existing().orderId;
      allow delete: if false;
    }

    // 7. Dispatches Collection
    match /dispatches/{dispatchId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(dispatchId) && isTenantMember(incoming().tenantId) && getUserRole() in ['admin', 'dispatch', 'management'] 
        && exists(/databases/$(database)/documents/orders/$(incoming().orderId)) && isValidDispatch(incoming());
      allow update: if isSignedIn() && isValidId(dispatchId) && isTenantMember(existing().tenantId) && getUserRole() in ['admin', 'dispatch', 'management'] 
        && isValidDispatch(incoming()) && incoming().tenantId == existing().tenantId && incoming().orderId == existing().orderId;
      allow delete: if false;
    }

    // 8. WhatsAppLogs Collection
    match /whatsappLogs/{logId} {
      allow get: if isTenantMember(resource.data.tenantId);
      allow list: if isSignedIn() && resource.data.tenantId == getUserTenantId();
      allow create: if isSignedIn() && isValidId(logId) && isTenantMember(incoming().tenantId) && isValidWhatsAppLog(incoming());
      allow update: if false;
      allow delete: if false;
    }
  }
}
